        }

        .service-card h4 {
            font-size: 1.2rem;
            font-weight: 500;
            color: #3a5a40;
            margin-bottom: 5px;
        }

        .service-card p {
            font-size: 0.85rem;
            color: #6f7e63;
        }

        /* Menu grid */
        .menu-section-title {
            margin: 40px 0 20px;
            font-size: 1.8rem;
            font-weight: 350;
            color: #3a5a40;
            border-left: 5px solid #a3b89a;
            padding-left: 18px;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        .menu-card {
            background: white;
            border-radius: 18px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
            border: 1px solid #d8e4cd;
        }

        .menu-card h3 {
            font-size: 1.4rem;
            font-weight: 400;
            color: #3a5a40;
            border-bottom: 1px dashed #b8c8aa;
            padding-bottom: 10px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .menu-item {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding: 8px 0;
            border-bottom: 1px dotted #d0ddc3;
            font-size: 0.95rem;
        }

        .menu-item .name {
            color: #2c3e2f;
        }

        .menu-item .price {
            color: #3a5a40;
            font-weight: 600;
        }

        .amharic {
            font-family: 'Nyala', 'Noto Sans Ethiopic', sans-serif;
        }

        .note {
            font-size: 0.8rem;
            color: #889b7a;
            margin-top: 8px;
            padding: 5px 0 0 8px;
        }

        /* Order & Payment area — Blue Park style */
        .order-section {
            margin-top: 50px;
            background: #f4f8ee;
            border-radius: 24px;
            padding: 30px 25px;
            border: 1px solid #c6d6b8;
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .order-header h2 {
            font-weight: 350;
            color: #2c4b2c;
            font-size: 1.8rem;
        }

        .order-empty {
            color: #8ba07e;
            font-style: italic;
            padding: 15px 0;
            text-align: center;
            border: 1px dashed #a7bb97;
            border-radius: 30px;
            margin-bottom: 30px;
        }

        .total-row {
            font-size: 1.5rem;
            font-weight: 600;
            color: #1e3a1e;
            margin: 20px 0;
        }

        .payment-methods {
